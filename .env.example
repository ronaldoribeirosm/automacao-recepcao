# Copie este arquivo para ".env" e preencha os valores reais.
# O ".env" nunca é commitado (veja .gitignore).

# --- Cloudbeds ---
# Gerado em: Cloudbeds > Account > Apps & Marketplace > New Credentials
# Escopos necessários: Reserva (Ler), Hóspede (Ler/Escreva),
# Campos Personalizados (Ler/Escreva), Data Insights Occupancy (Ler), Acomodação (Ler)
CLOUDBEDS_API_KEY=
CLOUDBEDS_PROPERTY_ID=
CLOUDBEDS_API_BASE=https://hotels.cloudbeds.com/api/v1.2

# --- Google Sheets (só leitura) ---
# Caminho para o JSON da service account do Google Cloud
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET_NAME=Hóspedes
# Nome das colunas na planilha usadas no match
SHEET_NAME_COLUMN=nome
SHEET_SECONDARY_COLUMN=cpf

# --- Comportamento do sistema ---
# "true" = nunca grava de verdade, só mostra o que faria (recomendado até validar tudo)
DRY_RUN=true
# Similaridade mínima de nome (0.0 a 1.0) pra considerar um candidato de match
MATCH_SCORE_THRESHOLD=0.87
# Quantos anos pra trás olhar ao contar estadias anteriores
HISTORY_LOOKBACK_YEARS=5
LOG_FILE_PATH=log.txt
# Mapeamento coluna da planilha -> campo do hóspede no Cloudbeds (JSON).
# Confirme os nomes reais de campo com uma chamada de teste à API antes de
# usar em produção — os valores abaixo são o ponto de partida.
# FIELD_MAPPING={"cpf":"guestCPF","telefone":"guestPhone1","email":"guestEmail","data_nascimento":"guestBirthdate","endereco":"guestAddress","nacionalidade":"guestCountry"}
